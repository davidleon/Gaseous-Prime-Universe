    rfl
  rw [h_def] at h_amp
  have h_abs : |A * Real.cos t| ≤ |A| := by
    have h_cos : |Real.cos t| ≤ 1 := by
      exact Real.abs_cos_le_one t
    calc |A * Real.cos t|
      = |A| * |Real.cos t| := by exact abs_mul A (Real.cos t)
      ≤ |A| * 1 := by
        exact mul_le_mul_of_nonneg_right h_cos (abs_nonneg A)
      = |A| := by ring
  have h_eq : A ≤ |A| := by
    rw [← h_amp]
    exact h_abs
  have h_abs_eq : A = |A| := by
    -- From A ≤ |A| and |A| ≤ A (by definition of abs)
