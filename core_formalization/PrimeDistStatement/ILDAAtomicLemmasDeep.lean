        rwa [one_div_le h_div h_exp_pos] at h_exp_le
      have h_exp_neg : Real.exp (-γ * N) = 1 / Real.exp (γ * N) := by
        exact Real.exp_neg (γ * N)
      rw [h_exp_neg]
      exact h_recip
    linarith
  rfl

