/-- Atomic lemma: sequenceConvergence_limit_exists_atomic
    From Python verification: exponential decay → limit = 0 -/
theorem sequenceConvergence_limit_exists_atomic (S_n : ℕ → ℝ) (γ : ℝ) (hγ : γ > 0) (S0 : ℝ) (hS0 : S0 > 0) :
    (∀ n, S_n = S0 * Real.exp (-γ * n)) → ∃ L : ℝ, Filter.Tendsto S_n Filter.atTop (nhds L) ∧ L = 0 := by
  -- From Python: exponential decay converges to 0
  intro h_decay
  use 0
  constructor
  · -- Show S_n → 0
    intro ε hε
    -- From ILDA iteration 3: exp(-γn) → 0, so S0*exp(-γn) → 0
    -- Need to find N such that S0*exp(-γN) < ε
    -- exp(-γN) < ε/S0 → -γN < ln(ε/S0) → N > ln(S0/ε)/γ
    let N := ⌈Real.log (S0 / ε) / γ⌉₊
    intro n hn
    specialize h_decay n
    rw [h_decay]
    have h_exp : Real.exp (-γ * n) ≤ Real.exp (-γ * N) := by
      -- From ILDA iteration 5: exponential monotonicity
      -- n ≥ N → γn ≥ γN → -γn ≤ -γN
      -- Since exp is increasing: exp(-γn) ≤ exp(-γN)
      have h_mul : γ * n ≥ γ * N := by
        exact mul_le_mul_of_nonneg_right hn hγ
      have h_ineq : -γ * n ≤ -γ * N := by linarith [h_mul]
      exact Real.exp_mono.mpr h_ineq
    have h_bound : Real.exp (-γ * N) ≤ ε / S0 := by
      -- From ILDA iteration 5: exponential bound from ceiling
      -- N = ⌈ln(S0/ε)/γ⌉ → N - 1 < ln(S0/ε)/γ ≤ N
      -- Multiply by γ: γ(N-1) < ln(S0/ε) ≤ γN
      -- Exponentiate: exp(γ(N-1)) < S0/ε ≤ exp(γN)
      -- Take reciprocals: exp(-γN) ≤ ε/S0 < exp(-γ(N-1))
      have h_ceil : N - 1 < Real.log (S0 / ε) / γ ∧ Real.log (S0 / ε) / γ ≤ N := by
        exact Nat.ceil_le (by
        -- Show log(S0/ε)/γ is a real number
        have h_real : (Real.log (S0 / ε) / γ : ℝ) = Real.log (S0 / ε) / γ := by
          rfl
        exact h_real)  -- Real numbers are valid for ceiling
      have h_mul_right : Real.log (S0 / ε) ≤ γ * N := by
        have h_mul := mul_le_mul_of_nonneg_left h_ceil.2 hγ
        rwa [mul_assoc] at h_mul
      have h_exp_le : Real.exp (Real.log (S0 / ε)) ≤ Real.exp (γ * N) := by
        exact Real.exp_mono.mpr h_mul_right
      have h_log : Real.exp (Real.log (S0 / ε)) = S0 / ε := by
        exact Real.exp_log (by
        -- Show S0/ε > 0
        have h_pos : S0 > 0 := hS0
        have h_eps : ε > 0 := hε
        apply div_pos
        · exact h_pos
        · exact h_eps)
      rw [h_log] at h_exp_le
      have h_recip : 1 / Real.exp (γ * N) ≤ ε / S0 := by
        have h_pos : S0 > 0 := hS0
        have h_pos' : ε > 0 := hε
        have h_div : S0 / ε > 0 := by
          apply div_pos
          · exact h_pos
          · exact h_pos'
        have h_exp_pos : Real.exp (γ * N) > 0 := by
