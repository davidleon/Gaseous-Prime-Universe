        -- exp(log(y)) = y for y > 0
        -- We need to show x^(1/m) > 0, which is true for x > 0
        have h_pos : x ^ (1 / m) > 0 := by
          apply Real.rpow_pos_of_pos
          exact h_x  -- x > 1 > 0
        have h_log_pos : Real.log (x ^ (1 / m)) = Real.log (x ^ (1 / m)) := by
          rfl
        rw [h_log_pos]
        exact Real.exp_log h_pos
      -- Now we need to show the exponents are equal
      have h_inj : Real.exp (Real.log (x ^ (1 / m))) = Real.exp ((1 / m) * Real.log x) →
        Real.log (x ^ (1 / m)) = (1 / m) * Real.log x := by
        intro h_eq
        -- exp is injective, so if exp(a) = exp(b), then a = b
        exact Real.exp_injective.mp h_eq
      apply h_inj
      -- Compute both sides
      have h_left : Real.exp (Real.log (x ^ (1 / m))) = x ^ (1 / m) := by
        have h_pos : x ^ (1 / m) > 0 := by
          apply Real.rpow_pos_of_pos
          exact h_x
        exact Real.exp_log h_pos
      have h_right : Real.exp ((1 / m) * Real.log x) = x ^ (1 / m) := by
        have h_pos : (1 / m) * Real.log x = Real.log x / m := by
          field_simp
        rw [h_pos]
        have h_log : Real.log x > 0 := by
          apply Real.log_pos
          exact h_x
        have h_exp_log : Real.exp (Real.log x / m) = (Real.exp (Real.log x))^(1/m) := by
          -- exp(a/m) = (exp(a))^(1/m)
          rw [Real.exp_div (Real.log x) h_m]
          exact (Real.exp (Real.log x)) ^ (1 / m)
        have h_exp_log_x : Real.exp (Real.log x) = x := by
          have h_pos : x > 0 := by linarith [h_x]
          exact Real.exp_log h_pos
        rw [h_exp_log, h_exp_log_x]
      rw [h_left, h_right]
  rw [h_log_pow]
  exact mul_pos h_pos h_log

