  have h_pos : 1 / m > 0 := by
    apply div_pos
    norm_num
    exact h_m
  have h_log_pow : Real.log (x ^ (1 / m)) = (1 / m) * Real.log x := by
      -- From ILDA iteration 6: logarithmic power property
      -- log(x^m) = m·log(x) for x > 0
      -- Therefore: log(x^(1/m)) = (1/m)·log(x)
