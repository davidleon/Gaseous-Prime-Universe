/-- Lemma: prime_power_pnt_well_defined_lemma1
    From Python verification: x^(1/m) > 1 for x > 1, m > 0 -/
theorem prime_power_pnt_well_defined_lemma1 (x m : ℝ) (h_x : x > 1) (h_m : m > 0) :
    Real.log (x ^ (1 / m)) > 0 := by
  -- From Python: log(x^(1/m)) = (1/m)·log(x) > 0 since log(x) > 0
