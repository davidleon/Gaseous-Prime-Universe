theorem improvement_increasing (Gamma0 lambda t1 t2 : Real) 
                               (hlambda : lambda > 0) (hGamma0 : Gamma0 > 0) 
                               (h1 : 0 <= t1) (h2 : t1 < t2) :
  improvement_metric (fun t => lyapunov_function Gamma0 lambda t) t2 > 
  improvement_metric (fun t => lyapunov_function Gamma0 lambda t) t1 := by
  have h_form1 := improvement_formula Gamma0 hlambda t1
  have h_form2 := improvement_formula Gamma0 hlambda t2
  rw [h_form1, h_form2]
  have h_exp : Real.exp (lambda * t2) > Real.exp (lambda * t1) := by
    apply Real.exp_strict_mono
    · linarith
    · linarith
