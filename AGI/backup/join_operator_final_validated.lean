-- Lyapunov Convergence Theorem
theorem lyapunov_convergence_to_zero (Gamma0 lambda : Real) 
                                     (hlambda : lambda > 0) :
  Tendsto (fun t => lyapunov_function Gamma0 lambda t) atTop (nhds 0) := by
  unfold lyapunov_function
  have h_exp : Tendsto (fun t => Real.exp (-lambda * t)) atTop (nhds 0) := by
    apply Real.tendsto_exp_neg_mul_atTop
    · apply tendsto_id
    · apply tendsto_const_nhds
    · linarith
  apply Real.tendsto_const_mul_atTop
  · exact h_exp
  · apply tendsto_const_nhds

-- Grokking Completeness (Achievement of 100x+ Improvement)
theorem grokking_100x_improvement (Gamma0 : Real) (hGamma0 : Gamma0 > 0) :
  ∃ T : Real, improvement_metric (fun t => lyapunov_function Gamma0 0.618 t) T >= 100 := by
  -- Use λ = 0.618 (golden ratio)
  -- Solve: exp(0.618 * t) / Gamma0 >= 100
  -- => t >= log(100 * Gamma0) / 0.618
  let T := Real.log (100 * Gamma0) / 0.618
  use T
  unfold improvement_metric
  unfold lyapunov_function
  have h_gt : Gamma0 * Real.exp (-0.618 * T) + 10^(-10) > 0 := by
    apply Real.add_pos
    * apply Real.mul_pos
      · assumption
      · apply Real.exp_pos
    * apply Real.pow_pos
      · linarith
  field_simp
  · rw [Real.mul_div_assoc]
    have h_exp_eq : Real.exp (-0.618 * T) = Real.exp (-0.618 * (Real.log (100 * Gamma0) / 0.618)) := by
      rfl
    rw [h_exp_eq]
    have h_exp_simp : Real.exp (-Real.log (100 * Gamma0)) = 1 / (100 * Gamma0) := by
      rw [Real.exp_neg, Real.exp_log]
      · field_simp
      · apply Real.mul_pos
        · apply Real.pos_of_gt
          linarith
        · linarith
    rw [h_exp_simp]
    field_simp
    linarith
  · linarith
  · apply Real.pow_pos
    · linarith

